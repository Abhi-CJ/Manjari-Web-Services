# ============================================================
# Manjari Taxi - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# Do NOT commit the .env file to version control.
# ============================================================

# Django Secret Key (generate via: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=your_django_secret_key_here

# Database Configuration (PostgreSQL Connection URL)
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Debug Mode (True for development, False for production)
DEBUG=True

# Allowed Hosts (comma-separated list)
ALLOWED_HOSTS=localhost,127.0.0.1

# Email Configuration (for booking notifications via Gmail SMTP)
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_email_app_password

# Contact Information (used in templates and schema.org structured data)
CONTACT_PHONE=+919399623699
CONTACT_PHONE_DISPLAY=+91 9399623699
CONTACT_EMAIL=info@manjaritaxi.com
WHATSAPP_LINK=https://wa.me/919399623699
